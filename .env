# Application
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/autopost.db

# Security - Test credentials (CHANGE IN PRODUCTION)
JWT_SECRET_KEY=test-secret-key-for-development-only-change-in-production

# TikTok API Configuration (use dummy values for testing)
TIKTOK_CLIENT_KEY=test_client_key_12345
TIKTOK_CLIENT_SECRET=test_client_secret_67890
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/tiktok/callback

# Upload Settings
UPLOAD_DIR=./uploads
UPLOAD_CHECK_INTERVAL=10
MAX_RETRIES=5
